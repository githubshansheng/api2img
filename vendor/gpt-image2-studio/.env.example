OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
RESPONSES_MODEL=gpt-5.4

# Local Node DNS fallback is enabled by default with 223.5.5.5 and 1.1.1.1.
# Set to 1 to keep Node's original DNS resolver list untouched.
IMAGE_STUDIO_DISABLE_DNS_FALLBACK=0
# Optional. Separate custom resolver IPs with commas, semicolons, or spaces.
IMAGE_STUDIO_DNS_FALLBACK_SERVERS=
