{
  "name": "gpt-image2-studio",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "本地优先的 AI 图像生成与视觉创作工作台",
  "scripts": {
    "start": "node server.mjs",
    "dev": "node server.mjs",
    "generate": "node generate-image.mjs",
