{
  "name": "api2image-workbench",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:client\" \"npm:dev:server\" \"npm:dev:studio-ref\"",
    "dev:client": "vite build && vite preview --host 0.0.0.0",
    "dev:client:hmr": "vite --host 0.0.0.0",
    "dev:server": "tsx watch server/index.ts",
    "dev:studio-ref": "node vendor/gpt-image2-studio/server.mjs",
    "studio-ref": "node vendor/gpt-image2-studio/server.mjs",
    "audit:studio-vendor": "node scripts/audit-gpt-studio-vendor.mjs",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run src/tests"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^5.0.0",
    "better-sqlite3": "^12.11.1",
    "concurrently": "^9.2.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "fabric": "^7.4.0",
    "gsplat": "^1.2.9",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "pngjs": "^7.0.0",
    "pptxgenjs": "^4.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2",
    "three": "^0.185.1",
    "tsx": "^4.20.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
